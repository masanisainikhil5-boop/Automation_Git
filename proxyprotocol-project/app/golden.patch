 #include "ProxyProtocol.h"
 #include <cstring>

 ProxyProtocol::ProxyProtocol()
 {
   additional_data = nullptr;
@@ -60,6 +60,15 @@ ProxyProtocol::ProxyProtocol()
 }

 ProxyProtocol::~ProxyProtocol()
 {
+  // Ensure allocated memory is released to prevent leaks.
+  if (additional_data != nullptr) {
+    ats_free(additional_data);
+    additional_data = nullptr;
+    additional_data_len = 0;
+  }
 }

 void
 ProxyProtocol::set_additional_data(const void *data, size_t len)
 {
+  // Free any previously allocated buffer before assigning new data.
+  if (additional_data != nullptr) {
+    ats_free(additional_data);
+    additional_data = nullptr;
+    additional_data_len = 0;
+  }
+
+  if (len == 0 || data == nullptr) {
+    return;
+  }
+}
   additional_data = static_cast<char *>(ats_malloc(len));
   memcpy(additional_data, data, len);
   additional_data_len = len;
